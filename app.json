{
  "expo": {
    "name": "Beck App",
    "slug": "beckapp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "beckcrmapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beckcrm.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.expotest2sorganization.beckapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-foreground-small.png",
        "backgroundColor": "#facc15"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/beck-splash-logo.png",
          "imageWidth": 340,
          "resizeMode": "contain",
          "backgroundColor": "#facc15",
          "dark": {
            "image": "./assets/images/beck-splash-logo.png",
            "backgroundColor": "#facc15"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9c9b4430-55be-4c2f-8536-fdb7a097bf02"
      }
    },
    "owner": "diseno1"
  }
}
